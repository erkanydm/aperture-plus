 # Aperture+ Environment Variables
# Copy this to .env and fill in your keys

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# FRED — FREE at fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key

# Tiingo — $10/month at tiingo.com
TIINGO_API_KEY=your_tiingo_key

# Beehiiv — from beehiiv.com/settings/integrations
BEEHIIV_API_KEY=your_beehiiv_key
BEEHIIV_PUBLICATION_ID=pub_your_id

# Twitter/X — developer.twitter.com ($100/month)
TWITTER_API_KEY=your_key
TWITTER_API_SECRET=your_secret
TWITTER_ACCESS_TOKEN=your_token
TWITTER_ACCESS_SECRET=your_token_secret
TWITTER_BEARER_TOKEN=your_bearer

# Buffer — buffer.com/developers ($18/month)
BUFFER_ACCESS_TOKEN=your_buffer_token
BUFFER_INSTAGRAM_PROFILE_ID=your_ig_id
BUFFER_LINKEDIN_PROFILE_ID=your_li_id

# Your details
SIGNAL_WEBSITE=https://aperture.plus
TEST_EMAIL=your@email.com
SEND_TIME=06:00
TIMEZONE=America/New_York